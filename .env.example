# ==========================================
# BASE DE DATOS
# ==========================================
# Para SQLite (desarrollo)
DATABASE_URL=sqlite:///./bajalta.db
# Para PostgreSQL (producción)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/sistema_rrhh
# Para MySQL (producción)
# DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost:3306/sistema_rrhh

# ==========================================
# SEGURIDAD JWT
# ==========================================
# ⚠️ GENERA UNA CLAVE SEGURA (mínimo 32 caracteres)
# Puedes generarla con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=tu_clave_secreta_muy_segura_de_al_menos_32_caracteres
JWT_ALG=HS256
JWT_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# API
# ==========================================
PROJECT_NAME=Bajalta

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# EMAIL
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contraseña
EMAIL_FROM=tu_correo@gmail.com
EMAIL_FROM_NAME=Bajalta
SMTP_USE_TLS=True
SMTP_USE_SSL=False